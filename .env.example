# Environment overrides for the uma4agents demo stack.
# Copy to .env to change any of these. All have working defaults in
# docker-compose.yml — see the "Demo credentials — not secrets" section of the
# README. These are LOCAL LAB defaults, not secrets; do not reuse them anywhere
# real or expose this stack on a public network.

# Keycloak bootstrap admin password
KC_ADMIN_PASSWORD=uma4agents-admin

# Shared token the portal uses to reach the authorization server's owner API
UMA_AS_OWNER_TOKEN=owner-dev-portal

# Protection API access token the gateway/PEP uses at the authorization server
UMA_AS_PAT=pat-dev-gateway

# Portal browser-session signing secret
PORTAL_SESSION_SECRET=dev-session-secret

# Person-server admin/person token
PS_ADMIN_TOKEN=uma4agents-ps-admin

# Set to "none" to bypass OIDC login in headless environments
# PORTAL_AUTH=oidc
